{
  "expo": {
    "name": "SAFEFLOOR",
    "slug": "safefloor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/safefloor-icon.png",
    "scheme": "safefloor",
    "userInterfaceStyle": "dark",
    "ios": { "supportsTablet": false },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07111D",
        "foregroundImage": "./assets/brand/safefloor-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/brand/safefloor-icon.png"
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SAFEFLOOR nutzt deinen Standort nur, um dich auf der Karte zu orientieren. Er wird nicht veröffentlicht."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#07111D",
          "image": "./assets/brand/safefloor-icon.png",
          "imageWidth": 112
        }
      ]
    ],
    "experiments": {
      "baseUrl": "/safefloor",
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
